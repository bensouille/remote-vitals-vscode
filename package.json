{
  "name": "remote-vitals",
  "displayName": "Remote Vitals",
  "description": "Live CPU / RAM / Disk / Network metrics from any remote SSH host — no agent install required. Reads /proc directly as a VS Code Workspace extension.",
  "version": "0.1.21",
  "publisher": "remote",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "remote",
    "ssh",
    "metrics",
    "cpu",
    "ram",
    "disk",
    "monitoring",
    "glances",
    "vitals"
  ],
  "extensionKind": [
    "workspace"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/remote-vitals-vscode.git"
  },
  "activationEvents": [
    "*",
    "onStartupFinished",
    "onCommand:remoteVitals.showPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "remoteVitals.showPanel",
        "title": "Remote Vitals: Show Panel",
        "icon": "$(pulse)"
      },
      {
        "command": "remoteVitals.refresh",
        "title": "Remote Vitals: Refresh Now",
        "icon": "$(refresh)"
      },
      {
        "command": "remoteVitals.configure",
        "title": "Remote Vitals: Configure Dashboard Push",
        "icon": "$(settings-gear)"
      },
      {
        "command": "remoteVitals.checkForUpdates",
        "title": "Remote Vitals: Check for Updates",
        "icon": "$(cloud-download)"
      },
      {
        "command": "remoteVitals.installAgent",
        "title": "Remote Vitals: Install Background Agent",
        "icon": "$(server-process)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "remoteVitals.showPanel"
        },
        {
          "command": "remoteVitals.refresh"
        },
        {
          "command": "remoteVitals.configure"
        },
        {
          "command": "remoteVitals.checkForUpdates"
        },
        {
          "command": "remoteVitals.installAgent"
        }
      ]
    },
    "configuration": {
      "title": "Remote Vitals",
      "properties": {
        "remoteVitals.refreshInterval": {
          "type": "number",
          "default": 5,
          "minimum": 2,
          "maximum": 300,
          "markdownDescription": "Refresh interval in seconds (default: 5)"
        },
        "remoteVitals.backendUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "Dashboard backend URL, e.g. `https://dashboard.example.com`. When set (with `agentToken`), metrics and VS Code sessions are pushed at each refresh — no need to install `agent.py` on this host."
        },
        "remoteVitals.agentToken": {
          "type": "string",
          "default": "",
          "markdownDescription": "Secret token matching the `AGENT_TOKEN` environment variable on the backend (`openssl rand -hex 32`)."
        },
        "remoteVitals.hostAlias": {
          "type": "string",
          "default": "",
          "markdownDescription": "SSH config alias for this host (e.g. `MiniPC`). Used to build the `vscode://` deep-link in the dashboard. Defaults to the system hostname."
        },
        "remoteVitals.sshUser": {
          "type": "string",
          "default": "",
          "markdownDescription": "SSH user for this host (e.g. `root`). Combined with `hostAlias` to form `user@host` in the dashboard deep-link."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.22.0"
  }
}
